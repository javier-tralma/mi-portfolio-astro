---
import { Code2, Server, ArrowDown } from "@lucide/astro";
import FocusName from "./FocusName";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-24 pb-16 overflow-hidden"
>
  <!-- Layer 1: Decorative radial glow (ambient) -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-text-accent/8 rounded-full blur-[150px] pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-5xl mx-auto text-center">
    <!-- Layer 2: Badges -->
    <div class="flex flex-wrap items-center justify-center gap-3 mb-10">
      <span
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase border border-white/[0.08] bg-white/[0.04] text-text-secondary"
      >
        <Code2 class="w-3.5 h-3.5 text-text-accent" />
        {t("hero.badge1")}
      </span>
      <span
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase border border-white/[0.08] bg-white/[0.04] text-text-secondary"
      >
        <Server class="w-3.5 h-3.5 text-text-accent" />
        {t("hero.badge2")}
      </span>
    </div>

    <!-- Focus Mask Effect Layer: Name + Title -->
    <div class="relative inline-block mb-8">
      <!-- Animated Halo Blob (behind text) -->
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] sm:w-[800px] sm:h-[400px] pointer-events-none"
        aria-hidden="true"
      >
        <div
          class="halo-blob w-full h-full rounded-full opacity-70"
        ></div>
      </div>

      <FocusName
        className="relative z-10"
        client:load
      >
        <p class="text-5xl sm:text-6xl md:text-7xl font-black tracking-tighter text-white uppercase mb-4">
          JAVIER TRALMA
        </p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black tracking-tighter leading-[0.9]">
          <span class="block text-white">{t("hero.title1")}</span>
          <span class="block text-text-accent">
            {t("hero.title2")}
          </span>
        </h1>
      </FocusName>
    </div>

    <!-- Layer 5: Subtitle -->
    <p
      class="max-w-2xl mx-auto text-base sm:text-lg md:text-xl text-text-secondary leading-relaxed mb-10"
    >
      {t("hero.subtitle")}
    </p>

    <!-- Layer 6: CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#projects"
        class="group inline-flex items-center gap-2 px-8 py-3.5 rounded-full text-sm font-semibold bg-text-accent text-[#0a0a0a] hover:bg-[#c4b5fd] transition-colors duration-300"
      >
        {t("hero.ctaProjects")}
        <ArrowDown class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" />
      </a>
      <a
        href="#about"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full text-sm font-semibold border-[1.5px] border-white/[0.12] text-white hover:bg-white/[0.06] transition-all duration-300"
      >
        {t("hero.ctaAbout")}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-60">
    <span class="text-[10px] uppercase tracking-widest text-text-secondary">{t("hero.scroll")}</span>
    <div class="w-[1px] h-8 bg-gradient-to-b from-text-secondary to-transparent"></div>
  </div>
</section>

<style>
  @keyframes gradient-shift {
    0% { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  /* Halo Blob Animation */
  .halo-blob {
    background: radial-gradient(circle at 30% 30%, rgba(167, 139, 250, 0.8), rgba(139, 92, 246, 0.6) 40%, rgba(88, 28, 135, 0.4) 70%, transparent 100%);
    filter: blur(40px) saturate(150%);
    animation: halo-pulse 8s ease-in-out infinite, halo-float 12s ease-in-out infinite;
  }

  @keyframes halo-pulse {
    0%, 100% {
      opacity: 0.6;
      transform: scale(1);
    }
    50% {
      opacity: 0.9;
      transform: scale(1.15);
    }
  }

  @keyframes halo-float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(10px, -8px) scale(1.08);
    }
    50% {
      transform: translate(-5px, 5px) scale(1.15);
    }
    75% {
      transform: translate(8px, 10px) scale(1.05);
    }
  }
</style>

---

<section id="skills" class="relative px-6 py-24">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-white">
        {t("skills.title")}
      </h2>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-3">
      {
        skills.map((skill) => (
          <div class="group flex items-center gap-2.5 px-4 py-2.5 rounded-full bg-white/[0.04] border border-white/[0.08] hover:bg-white/[0.08] hover:border-white/[0.14] transition-all duration-300 cursor-default select-none">
            <div class="w-5 h-5 flex items-center justify-center" set:html={skill.icon} />
            <span class="text-sm font-medium text-white">{skill.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

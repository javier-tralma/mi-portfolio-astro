---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { label: t("about.stats.projects"), value: "3+" },
  { label: t("about.stats.years"), value: "2+" },
  { label: t("about.stats.coffee"), value: "∞" },
];
---

<section id="about" class="relative px-6 py-24">
  <div class="max-w-6xl mx-auto">
    {/* Title */}
    <h2 class="text-4xl sm:text-5xl font-bold text-center text-white tracking-tight mb-16 sm:mb-20">
      {t("about.title")} <span class="text-text-accent">{t("about.titleAccent")}</span>
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      {/* Left Column - Bio + Stats */}
      <div class="flex flex-col gap-8">
        <div class="space-y-5">
          <p class="text-base sm:text-lg text-text-secondary leading-relaxed" set:html={t("about.bio1")} />
          <p class="text-base sm:text-lg text-text-secondary leading-relaxed">
            {t("about.bio2")}
          </p>
        </div>

        {/* Stats */}
        <div class="grid grid-cols-3 gap-4 pt-6 border-t border-white/[0.08]">
          {stats.map((stat) => (
            <div class="text-center">
              <span class="block text-3xl sm:text-4xl font-black text-text-accent tracking-tighter mb-1">
                {stat.value}
              </span>
              <span class="text-xs sm:text-sm text-text-secondary">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      {/* Right Column - Terminal */}
      <div class="w-full">
        <div class="rounded-xl border border-white/[0.08] bg-[#0d0d0d]/80 backdrop-blur-sm overflow-hidden shadow-2xl">
          {/* Terminal Header */}
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/[0.06] bg-white/[0.02]">
            <div class="flex items-center gap-1.5">
              <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
              <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
              <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
            </div>
            <span class="text-xs text-text-secondary/60 font-mono ml-2">terminal</span>
          </div>

          {/* Terminal Body */}
          <div class="p-5 sm:p-6 font-mono text-sm leading-relaxed">
            <div class="mb-4">
              <span class="text-text-accent">$</span>
              <span class="text-text-secondary ml-2">{t("about.terminal.command")}</span>
            </div>

            <div class="space-y-3 text-text-secondary/90">
              <div class="grid grid-cols-[80px_1fr] sm:grid-cols-[100px_1fr] gap-2">
                <span class="text-text-secondary/50">{t("about.terminal.label.name")}</span>
                <span class="text-white/90">{t("about.terminal.value.name")}</span>
              </div>
              <div class="grid grid-cols-[80px_1fr] sm:grid-cols-[100px_1fr] gap-2">
                <span class="text-text-secondary/50">{t("about.terminal.label.role")}</span>
                <span class="text-white/90">{t("about.terminal.value.role")}</span>
              </div>
              <div class="grid grid-cols-[80px_1fr] sm:grid-cols-[100px_1fr] gap-2">
                <span class="text-text-secondary/50">{t("about.terminal.label.location")}</span>
                <span class="text-white/90">{t("about.terminal.value.location")}</span>
              </div>

              <div class="pt-2 text-text-secondary/80">
                <p>{t("about.terminal.output.line1")}</p>
                <p>{t("about.terminal.output.line2")}</p>
              </div>

              <div class="pt-1 text-text-secondary/80">
                <p>{t("about.terminal.output.line3")}</p>
                <p>{t("about.terminal.output.line4")}</p>
              </div>
            </div>

            <div class="mt-5 flex items-center gap-2">
              <span class="text-text-accent">$</span>
              <span class="inline-block w-2 h-4 bg-text-accent/80 rounded-sm animate-pulse"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
</section>
